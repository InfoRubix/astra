# Firebase Configuration
# Get these values from Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps > Firebase SDK snippet > Config

REACT_APP_FIREBASE_API_KEY=your-api-key-here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# Firebase Cloud Messaging (FCM) VAPID Key
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Used by: fcmNotificationService.js, pushNotificationService.js for push notifications
REACT_APP_FIREBASE_VAPID_KEY=your-vapid-key-here

# Google Maps API Key
# Get from: https://console.cloud.google.com/google/maps-apis/
# Used by: CheckInPreviewMap, AttendanceMap, LocationSearchBox, Attendance page
REACT_APP_GOOGLE_PLACES_API_KEY=your-google-maps-api-key

# Calendarific API Key (Malaysia holidays - free 1000 req/month)
# Get from: https://calendarific.com/signup
REACT_APP_CALENDARIFIC_API_KEY=your-calendarific-api-key

# Optional: Enable Firebase Emulator (for local development)
# REACT_APP_USE_EMULATOR=true

# Email Configuration (for Cloud Functions - see also functions/.env.example)
# These are NOT used by the React app directly; they belong in functions/.env
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# APP_URL=http://localhost:3000
