# =============================================================================
# Firebase Cloud Functions - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values before deploying.
#
# IMPORTANT: Never commit the .env file with real credentials to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Email Configuration (Nodemailer)
# -----------------------------------------------------------------------------
# Used by: sendCheckInReminders, sendCheckOutReminders, autoCheckoutBeforeMidnight,
#          onLeaveStatusUpdate (leave approval/rejection emails)
#
# For Gmail: You must use an App Password (not your regular password).
# Generate one at: https://myaccount.google.com/apppasswords
# For other providers: Change the 'service' in getEmailTransporter() in index.js
# Supported services: gmail, outlook, yahoo, or custom SMTP

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# -----------------------------------------------------------------------------
# Application URL
# -----------------------------------------------------------------------------
# Used in email templates for "Check In Now", "Check Out Now", and
# "View Attendance" button links.
# Set this to your deployed frontend URL (no trailing slash).

APP_URL=https://your-app-domain.com
