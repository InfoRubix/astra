rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // SIMPLIFIED RULES FOR DEBUGGING - ADMINS HAVE FULL ACCESS

    // FCM Tokens - Allow Cloud Functions service account to read/write
    // Cloud Functions need this to send notifications
    match /fcmTokens/{tokenId} {
      allow read, write: if isAuthenticated();
      allow read, write: if request.auth.token.firebase.sign_in_provider == 'custom'; // Service accounts
    }

    // Company Settings - Allow Cloud Functions to read
    match /companySettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow read: if request.auth.token.firebase.sign_in_provider == 'custom'; // Service accounts
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      // Allow Cloud Functions to read for notification purposes
      allow read: if request.auth.token.firebase.sign_in_provider == 'custom';
    }

    // Attendance collection - Full admin access
    match /attendance/{attendanceId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Leaves collection - Full admin access
    match /leaves/{leaveId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Claims collection - Full admin access
    match /claims/{claimId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications collection - Full admin access
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (resource.data.get('userId', null) != null && isOwner(resource.data.userId));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (resource.data.get('userId', null) != null && isOwner(resource.data.userId));
      allow delete: if isAdmin();
    }

    // Other collections - Allow all for authenticated users
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}